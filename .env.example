# Environment Variables for AI-Powered UI Component Generator
# 
# This file contains environment variables needed for the application.
# Copy this file to .env and fill in your actual API keys.
# 
# IMPORTANT: Never commit .env files with real API keys to version control!
# 
# Author: M.H. Nishan Sathsara
# Project: AI-Powered UI Component Generator

# =============================================================================
# AI API CONFIGURATION
# =============================================================================

# xAI Grok API Key (Preferred)
# Get your API key from: https://x.ai/api
# This is the primary AI service for component generation
VITE_XAI_API_KEY=your_xai_grok_api_key_here

# OpenAI GPT-4 API Key (Fallback)
# Get your API key from: https://platform.openai.com/api-keys
# This serves as a backup AI service
VITE_OPENAI_API_KEY=your_openai_api_key_here

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Environment mode (development, production, testing)
VITE_APP_ENV=development

# API timeout in milliseconds
VITE_API_TIMEOUT=30000

# Default AI provider (grok or openai)
VITE_DEFAULT_AI_PROVIDER=grok

# Enable/disable mock API for development (true/false)
VITE_USE_MOCK_API=true

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Enable debug logging (true/false)
VITE_DEBUG_MODE=true

# Maximum tokens for AI requests
VITE_MAX_TOKENS=2000

# AI temperature setting (0.0 to 1.0)
VITE_AI_TEMPERATURE=0.7

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# CORS origins (comma-separated list for production)
VITE_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate limiting (requests per minute)
VITE_RATE_LIMIT=60

# =============================================================================
# INSTRUCTIONS FOR SETUP
# =============================================================================
# 
# 1. Copy this file to .env in your project root
# 2. Replace the placeholder values with your actual API keys
# 3. Make sure .env is added to your .gitignore file
# 4. Restart your development server after making changes
# 
# For xAI Grok API:
# - Visit https://x.ai/api to sign up and get your API key
# - The API is currently in beta, so you may need to join a waitlist
# 
# For OpenAI API:
# - Visit https://platform.openai.com/ to create an account
# - Go to API Keys section and create a new secret key
# - Note: OpenAI API usage is paid based on tokens consumed
# 
# For development:
# - You can set VITE_USE_MOCK_API=true to test without real API keys
# - The mock API simulates realistic AI responses for development
# 
# =============================================================================
